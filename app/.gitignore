# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android release signing — keep secrets out of git. The keystore is
# the source of truth for Play Store updates; lose it and you can't
# ship signed updates. Back it up out-of-band (see iCloud copy in
# Flutterando/remotepi).
android/key.properties
android/signing/
*.jks
*.keystore
