<?xml version="1.0" encoding="UTF-8"?>
<!-- AppStream metadata (mínimo) para empacotamento Linux. Instalado em
     share/metainfo/. O <id> casa com o app ID e o .desktop. -->
<component type="desktop-application">
  <id>work.jacobmoura.cockpit</id>
  <name>Remote Pi Cockpit</name>
  <summary>Cliente desktop multi-pane do Remote Pi</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <!-- Licença do projeto ainda pendente no monorepo; placeholder válido. -->
  <project_license>LicenseRef-proprietary</project_license>

  <developer id="work.jacobmoura">
    <name>Jacob Moura</name>
  </developer>

  <description>
    <p>
      Cockpit é o cliente desktop do Remote Pi: uma GUI multi-pane sobre o motor
      do Pi. Roda agentes (cada um um <code>pi --mode rpc</code>) e terminais
      lado a lado, com árvore de arquivos, worktrees por workspace e
      agendamento de daemons.
    </p>
  </description>

  <launchable type="desktop-id">work.jacobmoura.cockpit.desktop</launchable>

  <url type="homepage">https://jacobmoura.work</url>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="1.0.0" date="2026-06-12">
      <description>
        <p>Primeira release distribuível do Cockpit.</p>
      </description>
    </release>
  </releases>
</component>
